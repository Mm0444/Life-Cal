<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>

<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.lifecal.controller.ProfileEditController"
      styleClass="container" spacing="24">
    
    <Label text="แก้ไขโปรไฟล์" styleClass="label-heading"/>
    
    <VBox styleClass="card" spacing="16">
        <GridPane hgap="20" vgap="16">
            <Label text="ชื่อผู้ใช้:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
            <TextField fx:id="usernameField" GridPane.rowIndex="0" GridPane.columnIndex="1" prefWidth="300"/>
            
            <Label text="อีเมล:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
            <TextField fx:id="emailField" promptText="example@mail.com" GridPane.rowIndex="1" GridPane.columnIndex="1" prefWidth="300"/>
            
            <Label text="น้ำหนักปัจจุบัน (กก.):" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
            <TextField fx:id="weightField" GridPane.rowIndex="2" GridPane.columnIndex="1"/>
            
            <Label text="ส่วนสูง (ซม.):" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
            <TextField fx:id="heightField" GridPane.rowIndex="3" GridPane.columnIndex="1"/>
            
            <Label text="น้ำหนักเป้าหมาย (กก.):" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
            <TextField fx:id="targetWeightField" GridPane.rowIndex="4" GridPane.columnIndex="1"/>
            
            <Label text="ระดับกิจกรรม:" GridPane.rowIndex="5" GridPane.columnIndex="0"/>
            <ComboBox fx:id="activityLevelCombo" GridPane.rowIndex="5" GridPane.columnIndex="1" prefWidth="300"/>
            
            <Label text="ความถี่ในการออกกำลังกาย:" GridPane.rowIndex="6" GridPane.columnIndex="0"/>
            <ComboBox fx:id="exerciseFrequencyCombo" GridPane.rowIndex="6" GridPane.columnIndex="1" prefWidth="300"/>
        </GridPane>
    </VBox>
    
    <HBox spacing="12">
        <Button text="💾 บันทึกการเปลี่ยนแปลง" onAction="#handleSave" minWidth="150"/>
        <Button text="ยกเลิก" onAction="#handleCancel" styleClass="button-secondary" minWidth="150"/>
    </HBox>
</VBox>
