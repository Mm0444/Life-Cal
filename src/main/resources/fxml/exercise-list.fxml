<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.GridPane?>

<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.lifecal.controller.ExerciseListController"
      styleClass="container" spacing="16">
    
    <Label fx:id="categoryLabel" text="หมวดหมู่การออกกำลังกาย" styleClass="label-heading">
        <VBox.margin>
            <Insets bottom="8"/>
        </VBox.margin>
    </Label>
    
    <!-- Logging Controls -->
    <VBox styleClass="card" spacing="12">
        <Label text="บันทึกการออกกำลังกาย" styleClass="label-subheading"/>
        <GridPane hgap="12" vgap="12">
            <Label text="วันที่:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
            <DatePicker fx:id="datePicker" GridPane.columnIndex="1" GridPane.rowIndex="0" maxWidth="200"/>
            
            <Label text="ระยะเวลา (นาที):" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
            <TextField fx:id="durationField" promptText="เช่น 30" GridPane.columnIndex="1" GridPane.rowIndex="1" maxWidth="200"/>
        </GridPane>
        <Label text="เลือกรายการออกกำลังกายจากตารางด้านล่างแล้วกดปุ่ม 'บันทึก'" styleClass="label-secondary" style="-fx-font-style: italic;"/>
    </VBox>
    
    <TableView fx:id="exerciseTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="nameColumn" text="ชื่อการออกกำลังกาย" prefWidth="350"/>
            <TableColumn fx:id="caloriesPerMinColumn" text="แคลอรี่/นาที (กิโลแคลอรี่)" prefWidth="200"/>
            <TableColumn fx:id="actionColumn" text="การกระทำ" prefWidth="100"/>
        </columns>
    </TableView>
    
    <Button text="← กลับไปหมวดหมู่" onAction="#handleBack" styleClass="button-secondary" maxWidth="200"/>
</VBox>
